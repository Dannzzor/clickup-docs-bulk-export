{
  "name": "clickup-docs-exporter",
  "version": "1.0.0",
  "description": "Export ClickUp Docs and Wikis to markdown files with full hierarchy preservation",
  "main": "dist/cli.js",
  "bin": {
    "clickup-docs-exporter": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "dashboard": "concurrently -n api,ui -c blue,magenta \"tsx watch src/dashboardServer.ts\" \"npm run dev --prefix dashboard\"",
    "dashboard:build": "npm run build && npm run build --prefix dashboard",
    "dashboard:serve": "npm run dashboard:build && node dist/dashboardServer.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "clickup",
    "export",
    "markdown",
    "docs",
    "wiki",
    "backup",
    "documentation",
    "cli"
  ],
  "author": "Toumi Abderrahmane",
  "license": "MIT",
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abderrahmaneMustapha/clickup-docs-bulk-export.git"
  },
  "bugs": {
    "url": "https://github.com/abderrahmaneMustapha/clickup-docs-bulk-export/issues"
  },
  "homepage": "https://github.com/abderrahmaneMustapha/clickup-docs-bulk-export#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
